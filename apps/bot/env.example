# Copy to .env.local and fill in values

# ─── AI ──────────────────────────────────────────────
# Vercel AI Gateway (recommended)
AI_GATEWAY_API_KEY=""

# Or direct provider keys
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""

# ─── Slack ───────────────────────────────────────────
SLACK_BOT_TOKEN=""
SLACK_SIGNING_SECRET=""

# ─── State (Redis) ───────────────────────────────────
REDIS_URL=""  # Required for thread subscriptions and locking

# ─── Observability (opt-in) ─────────────────────────
# TELEMETRY_ENABLED=true
# TELEMETRY_CONSOLE=true
# LANGFUSE_PUBLIC_KEY=""
# LANGFUSE_SECRET_KEY=""
# LANGSMITH_API_KEY=""
# OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
